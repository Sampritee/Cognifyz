<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Web Developer Internship | Cognifyz Technologies</title>

  <style>
    /* ---------- General Styles ---------- */
    body {
      font-family: 'Segoe UI', Arial, sans-serif;
      margin: 0;
      background-color: #f9fafb;
      color: #333;
      line-height: 1.6;
    }

    header {
      background-color: #0077b6;
      color: white;
      text-align: center;
      padding: 60px 20px;
    }

    header h1 {
      font-size: 32px;
      margin-bottom: 10px;
    }

    header p {
      font-size: 18px;
      max-width: 700px;
      margin: 0 auto;
    }

    /* ---------- Sections ---------- */
    section {
      max-width: 1000px;
      margin: 40px auto;
      padding: 0 20px;
    }

    h2 {
      color: #0077b6;
      margin-bottom: 10px;
    }

    ul {
      list-style: none;
      padding: 0;
    }

    ul li {
      background: #e0f0ff;
      margin: 8px 0;
      padding: 10px 15px;
      border-left: 5px solid #0077b6;
      border-radius: 5px;
    }

    /* ---------- Call-to-Action ---------- */
    .cta {
      text-align: center;
      margin: 50px 0;
    }

    .cta a {
      background-color: #0077b6;
      color: white;
      padding: 14px 30px;
      text-decoration: none;
      font-size: 18px;
      border-radius: 8px;
      transition: background 0.3s ease;
    }

    .cta a:hover {
      background-color: #005f8a;
    }

    /* ---------- Footer ---------- */
    footer {
      background-color: #023e8a;
      color: white;
      text-align: center;
      padding: 20px 10px;
      font-size: 15px;
    }

    footer a {
      color: #caf0f8;
      text-decoration: none;
    }

    footer a:hover {
      text-decoration: underline;
    }

    /* ---------- Responsive Design ---------- */
    @media (max-width: 768px) {
      header h1 {
        font-size: 26px;
      }

      header p {
        font-size: 16px;
      }

      .cta a {
        font-size: 16px;
        padding: 12px 25px;
      }
    }
  </style>
</head>

<body>
  <!-- Header -->
  <header>
    <h1>Web Developer Internship Opportunities at Cognifyz Technologies</h1>
    <p>
      Kickstart your career in web development with our hands-on internship program. 
      Gain practical experience, collaborate with experts, and enhance your technical skills.
    </p>
  </header>

  <!-- Internship Overview -->
  <section>
    <h2>About the Internship</h2>
    <p>
      This internship program runs for <strong>8 to 12 weeks</strong> and is designed for aspiring web developers 
      who want to explore real-world projects and learn from industry professionals. 
      Participants will work on live projects that strengthen their understanding of front-end and back-end technologies.
    </p>
  </section>

  <!-- Highlights -->
  <section>
    <h2>Internship Highlights</h2>
    <ul>
      <li>💻 Real-world project experience</li>
      <li>🧠 Mentorship from experienced developers</li>
      <li>🚀 Skill development through hands-on tasks</li>
      <li>🎓 Certificate of completion and performance feedback</li>
      <li>🤝 Networking opportunities within the tech community</li>
    </ul>
  </section>

  <!-- Qualifications -->
  <section>
    <h2>Desired Skills & Technologies</h2>
    <ul>
      <li>HTML, CSS, and JavaScript fundamentals</li>
      <li>Basic understanding of frameworks like React or Bootstrap</li>
      <li>Knowledge of Git/GitHub for version control</li>
      <li>Problem-solving and teamwork abilities</li>
      <li>Eagerness to learn and adapt to new tools</li>
    </ul>
  </section>

  <!-- Call to Action -->
  <div class="cta">
    <a href="#">Apply Now</a>
  </div>

  <!-- Footer -->
  <footer>
    <p>📧 For inquiries: <a href="mailto:hr@cognifyztech.com">hr@cognifyztech.com</a></p>
    <p>📍 Cognifyz Technologies | Nagpur, India</p>
  </footer>
</body>
</html>
